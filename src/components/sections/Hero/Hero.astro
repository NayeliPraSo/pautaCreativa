---
import "./hero.css";
import Section from "../../ui/Section/Section.astro";
import Heading from "../../ui/Heading/Heading.astro";
import Button from "../../ui/Button/Button.astro";
---

<Section id="hero" class="hero">
  <div class="hero-content">
    <Heading as="h1" size="xl">Pauta Creativa</Heading>
    <p class="hero-subtitle">
      Renovamos la presencia digital de tu marca con diseño, estrategia y tecnología.
    </p>
    <div class="hero-actions">
      <Button href="#contacto" variant="primary">Hablemos</Button>
      <Button href="#soluciones" variant="ghost">Ver soluciones</Button>
    </div>
  </div>
</Section>

<script>
  import "./hero.ts";
</script>
