---
import "./button.css";

interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  type?: "button" | "submit" | "reset";
  class?: string;
}

const {
  href,
  variant = "primary",
  type = "button",
  class: className = "",
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={href ? undefined : type}
  class={`ui-button ui-button--${variant} ${className}`}
>
  <slot />
</Tag>
