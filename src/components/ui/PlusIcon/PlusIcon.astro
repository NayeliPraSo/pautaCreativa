---
interface Props {
  size?: number;
  strokeWidth?: number;
  class?: string;
}

const { size = 30, strokeWidth = 2, class: className = "" } = Astro.props;
---

<svg
  class={`ui-plus-icon ${className}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M12 3v18M3 12h18"
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"></path>
</svg>
